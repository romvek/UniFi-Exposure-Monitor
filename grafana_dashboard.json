            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "Private \u2713" },
                "1": { "color": "red", "index": 1, "text": "PUBLIC \u2717" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },

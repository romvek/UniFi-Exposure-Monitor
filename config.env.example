# =============================================================================
# config.env.example — UniFi Exposure Monitor Configuration
#
# Copy this file to config.env and fill in your values.
# config.env is gitignored and should NEVER be committed to version control.
# =============================================================================

# Your UniFi controller hostname (used for DNS resolution check)
UNIFI_HOSTNAME="unifi.yourdomain.com"

# Your WAN IP address. Leave blank to auto-detect via api.ipify.org
WAN_IP=""

# Telegram bot token (from @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Do NOT include the word "bot" here — the script adds it automatically
TELEGRAM_BOT_TOKEN="your-token-here"

# Telegram chat ID (your personal or group chat ID)
# To find it: send a message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id":XXXXXXXXX}
TELEGRAM_CHAT_ID="your-chat-id-here"

# Prometheus Pushgateway URL
PUSHGATEWAY_URL="http://your-pushgateway-ip:9091"
